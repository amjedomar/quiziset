generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

generator json {
  provider = "prisma-json-types-generator"
}

datasource db {
  provider = "mysql"
}

model User {
  id             Int           @id @default(autoincrement())
  name           String        @db.VarChar(64)
  email          String        @unique @db.VarChar(255)
  password       String        @db.VarChar(1024)
  managedQuizzes Quiz[]
  quizSessions   QuizSession[]
  reviews        Review[]
  favorites      Favorite[]
}

model Quiz {
  id                    Int      @id @default(autoincrement())
  title                 String   @db.VarChar(255)
  description           String   @db.Text
  timeDurationInMinutes Int?
  imageUrl              String   @db.VarChar(1024)
  isPublic              Boolean  @default(false)
  isAnalyticsEnabled    Boolean  @default(false)
  totalFinishes         Int      @default(0)
  /// average rating (kept in sync with the data of the "review" table)
  /// it is stored here so the quizzes list can display/sort by rating quickly
  averageRating         Float    @default(0)
  /// [QuizQuestions]
  questions             Json
  managerId             Int
  manager               User     @relation(fields: [managerId], references: [id])
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  sessions              QuizSession[]
  reviews               Review[]
  favorites             Favorite[]
}

model Review {
  id        Int      @id @default(autoincrement())
  rating    Int // 1 to 5 whole stars (validated in the DTO)
  comment   String?  @db.VarChar(255)
  quizId    Int
  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// a user can leave at most one review per quiz
  @@unique([quizId, userId])
}

model Favorite {
  id        Int      @id @default(autoincrement())
  quizId    Int
  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  /// a user can favorite a quiz at most once
  @@unique([quizId, userId])
}

model QuizSession {
  id                     Int       @id @default(autoincrement())
  startTime              DateTime  @default(now())
  /// "expireTime" is null when the quiz has no time limit (i.e. when "timeDurationInMinutes" is null)
  expireTime             DateTime?
  /// "finishTime" is null until the quiz session is finished
  finishTime             DateTime?
  /// "questions" is a shuffled copy of the quiz questions (answers shuffled too)
  /// [QuizSessionQuestions]
  questions              Json
  questionsCount         Int
  successfulAnswersCount Int       @default(0)
  currentQuestionIndex   Int       @default(0)
  isAnalyticsShared      Boolean   @default(false)
  quizId                 Int
  quiz                   Quiz      @relation(fields: [quizId], references: [id])
  userId                 Int
  user                   User      @relation(fields: [userId], references: [id])
}
