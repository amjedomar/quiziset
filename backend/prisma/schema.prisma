generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

model User {
  id       Int    @id @default(autoincrement())
  name     String @db.VarChar(64)
  email    String @unique @db.VarChar(255)
  password String @db.VarChar(1024)
}
